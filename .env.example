# Copy to `.env` for local dev. Vite only exposes variables prefixed with VITE_.
#
# Supabase → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key
#
# Maa Jaanki backend (payment verify + WhatsApp)
VITE_API_URL=https://maajaanki-backend.vercel.app
VITE_ADMIN_VERIFY_KEY=maajaanki-admin-verify-2026
